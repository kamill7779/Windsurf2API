# Windsurf2API Configuration
# Copy this file to .env and adjust values as needed.

# HTTP server port
PORT=3003

# Path to Windsurf Language Server binary
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64

# gRPC port for Language Server communication
LS_PORT=42100

# Windsurf API server URL
API_SERVER_URL=https://server.self-serve.windsurf.com

# Admin password for dashboard & internal endpoints (leave empty to disable auth)
ADMIN_PASSWORD=
